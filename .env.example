# Copy this file to .env and fill in your values
# .env is gitignored and should NEVER be committed

# IP address of your EnvisaLink UNO on your local network
ENVISALINK_HOST=your.uno.ip.address

# TPI password (set in the UNO web interface under Settings)
ENVISALINK_PASSWORD=changeme

# Alarm user code (used to arm/disarm the panel)
ALARM_CODE=1234

# TPI port (default is 4025, rarely needs changing)
ENVISALINK_PORT=4025

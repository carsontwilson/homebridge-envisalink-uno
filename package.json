{
  "name": "homebridge-envisalink-uno",
  "version": "0.1.10",
  "description": "Homebridge plugin for the EnvisaLink UNO alarm system — auto-discovers zones, supports arm/disarm/night via HomeKit",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc && tsc -p tsconfig.ui.json",
    "watch": "tsc --watch",
    "lint": "eslint src --ext .ts",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist/",
    "homebridge-ui/",
    "config.schema.json",
    "CHANGELOG.md"
  ],
  "keywords": [
    "homebridge-plugin",
    "envisalink",
    "envisalink-uno",
    "eyezon",
    "uno",
    "security",
    "alarm",
    "security-system",
    "homekit",
    "honeywell",
    "vista"
  ],
  "author": "Carson Wilson",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/carsontwilson/homebridge-envisalink-uno"
  },
  "bugs": {
    "url": "https://github.com/carsontwilson/homebridge-envisalink-uno/issues"
  },
  "homepage": "https://github.com/carsontwilson/homebridge-envisalink-uno#readme",
  "engines": {
    "node": "^22.10.0 || ^24.0.0",
    "homebridge": "^1.8.0 || ^2.0.0"
  },
  "dependencies": {
    "@homebridge/plugin-ui-utils": "^2.2.3",
    "node-fetch": "^3.3.2"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "homebridge": "^2.0.0",
    "typescript": "^5.4.0"
  },
  "homebridge": {
    "displayName": "EnvisaLink UNO",
    "plugin_alias": "EnvisalinkUNO",
    "type": "platform"
  }
}
